# Copy to .env.local and fill with your own values. Never commit .env.local.
# Use your Neon, Supabase, or Vercel Postgres connection string (TLS usually required).

DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.provider.com:5432/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
FINNHUB_API_KEY=your-finnhub-api-key
